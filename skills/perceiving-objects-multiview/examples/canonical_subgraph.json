{
  "skill": "perceiving-objects-multiview",
  "inputs": {},
  "nodes": {
    "observe": {
      "type": "tool",
      "tool": "robot.get_observation"
    },
    "perceive_dino": {
      "type": "script",
      "script": "scripts/perceive_dino.py",
      "inputs": {
        "cameras": {"$ref": "observe.cameras"},
        "object_name": "basket"
      }
    },
    "perceive_point": {
      "type": "script",
      "script": "scripts/perceive_point.py",
      "inputs": {
        "cameras": {"$ref": "observe.cameras"},
        "object_name": "basket"
      }
    },
    "perceive_dino_vlm": {
      "type": "script",
      "script": "scripts/perceive_dino_vlm.py",
      "inputs": {
        "cameras": {"$ref": "observe.cameras"},
        "object_name": "basket"
      }
    },
    "merge": {
      "type": "script",
      "script": "scripts/merge.py",
      "inputs": {
        "cameras": {"$ref": "observe.cameras"},
        "object_name": "basket",
        "dino_result": {"$ref": "perceive_dino"},
        "point_result": {"$ref": "perceive_point"},
        "vlm_result": {"$ref": "perceive_dino_vlm"}
      }
    },
    "found": {"type": "noop"}
  },
  "edges": [
    ["START", "observe"],
    ["observe", "perceive_dino"],
    ["perceive_dino", "perceive_point"],
    ["perceive_point", "perceive_dino_vlm"],
    ["perceive_dino_vlm", "merge"],
    ["merge", "found"],
    ["found", "END"]
  ],
  "outputs": {
    "target_obb": {"$ref": "merge.obb"},
    "target_mask": {"$ref": "merge.mask"}
  },
  "exit": {"router_field": null, "success_values": ["found"]},
  "on_error": "not_found"
}
